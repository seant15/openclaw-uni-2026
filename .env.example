# OpenClaw Environment Variables
# Copy to .env and fill in your values (never commit .env to git)

# ==========================================
# REQUIRED - Gateway Configuration
# ==========================================
OPENCLAW_GATEWAY_TOKEN=your-secure-random-token-here

# ==========================================
# REQUIRED - Model API Keys
# ==========================================
KIMI_API_KEY=sk-your-kimi-key

# Optional - Other model providers
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ==========================================
# OPTIONAL - Slack Integration
# ==========================================
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# ==========================================
# OPTIONAL - Browser/CDP
# ==========================================
BROWSER_CDP_URL=http://browser:9223

# ==========================================
# OPTIONAL - Ports (defaults shown)
# ==========================================
# OPENCLAW_PORT=18789
# OPENCLAW_BRIDGE_PORT=18790
# OPENCLAW_BIND=lan
