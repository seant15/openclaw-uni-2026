# Coolify Environment Template (OpenClaw)
#
# IMPORTANT
# - Do NOT commit real secrets.
# - Fill values in Coolify UI (Environment Variables).
# - This file documents the required variable NAMES only.

# Basic auth for the bundled nginx (if you use it)
AUTH_USERNAME=
AUTH_PASSWORD=

# OpenClaw gateway auth token (long random string)
OPENCLAW_GATEWAY_TOKEN=

# Docker image tag (pin in production; see docs/UPGRADE.md)
OPENCLAW_IMAGE_TAG=2026.5.12
OPENCLAW_BROWSER_IMAGE_TAG=latest

# Host path to gateway JSON mounted at /app/config/openclaw.json
# Coolify example (replace UUID with your application id):
# OPENCLAW_CONFIG_HOST_PATH=/data/coolify/applications/ug0g8cs4kkw0040cwsswk40c/openclaw.json
OPENCLAW_CONFIG_HOST_PATH=

# CORS / Control UI — MUST be full origin(s), comma-separated (NOT hostname only).
# Wrong: open.uni-agency.com
# Right: https://open.uni-agency.com
OPENCLAW_ALLOWED_ORIGINS=https://open.uni-agency.com

# Slack (if enabled)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=

# Optional: model/provider keys (example placeholders)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional: reverse proxy/trust config (only if needed)
# OPENCLAW_TRUSTED_PROXIES=
# OPENCLAW_ALLOWED_HOSTS=
